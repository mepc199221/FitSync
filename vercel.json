{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://fitsync-d1x0.onrender.com/api/:path*"
    },
    {
      "source": "/signup",
      "destination": "https://fitsync-d1x0.onrender.com/signup"
    },
    {
      "source": "/Login",
      "destination": "https://fitsync-d1x0.onrender.com/Login"
    },
    {
      "source": "/user/:path*",
      "destination": "https://fitsync-d1x0.onrender.com/user/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
